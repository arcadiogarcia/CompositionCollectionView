<Window
    x:Class="CompositionCollectionView.Sample.WinUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:labs="using:CommunityToolkit.Labs.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CompositionCollectionView Sample">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock Text="CompositionCollectionView Samples"
                       Style="{ThemeResource TitleTextBlockStyle}"/>

            <!-- Card Fan & Layout Transitions -->
            <TextBlock Text="Card Fan &amp; Layout Transitions"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       Margin="0,24,0,0"/>
            <TextBlock Text="12 cards showcase five distinct layout algorithms with smooth animated transitions. Wave uses a live compositor-driven sine node."
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <ComboBox x:Name="layoutSelector" SelectedIndex="0" Width="160">
                    <ComboBoxItem Content="Fan"/>
                    <ComboBoxItem Content="Grid"/>
                    <ComboBoxItem Content="Spiral"/>
                    <ComboBoxItem Content="Orbit"/>
                    <ComboBoxItem Content="Wave"/>
                </ComboBox>
            </StackPanel>
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="12">
                <labs:CompositionCollectionView x:Name="cardFanView"
                                                Width="700"
                                                Height="350"
                                                HorizontalAlignment="Left"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
